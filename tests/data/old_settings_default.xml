<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<settings>
    <category label="General">
        <setting id="no_type" label="No Type" default="No typed text" />
        <setting id="text" type="text" label="Text" default="Hello World" />
        <setting id="bool" type="bool" label="Boolean" default="true" />
        <setting id="number" type="number" label="Number" default="3.14" />

        <setting id="slider_int" type="slider" label="Integer Slider"
                 option="int" range="0,1,100" default="42" />

        <setting id="slider_float" type="slider" label="Float Slider"
                 option="float" range="0,0.5,10" default="2.5" />

        <setting id="enum" type="enum" label="Enum"
                 values="One|Two|Three" default="1" />

        <setting id="select" type="select" label="Select"
                 values="Red|Green|Blue" default="2" />

        <setting id="lvalues_enum" type="enum" label="Localized Enum"
                 lvalues="30001|30002|30003" default="0" />

        <setting id="lvalues_select" type="select" label="Localized Select"
                 lvalues="30011|30012|30013" default="1" />

        <setting id="setting_file" type="file" label="File" default="/tmp/file.txt" />
        <setting id="setting_fileenum" type="fileenum" label="File" default="/tmp/file.txt" />
        <setting id="setting_audio" type="audio" label="File" default="/tmp/file.mp3" />
        <setting id="setting_video" type="video" label="File" default="/tmp/file.mp4" />
        <setting id="setting_image" type="image" label="File" default="/tmp/file.jpg" />
        <setting id="setting_executable" type="executable" label="File" default="/tmp/file.exe" />
        <setting id="setting_folder" type="folder" label="Folder" default="/tmp" />
        <setting id="path" type="path" label="Path" default="/storage" />

        <setting id="ip" type="ipaddress" label="IP Address" default="192.168.1.100" />
    </category>
</settings>